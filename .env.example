# ============================================
# 宿舍管理系统 - 环境变量配置
# 复制本文件为 .env 后修改实际值
# ============================================

# 数据库（PostgreSQL）
# 如果是阿里云 RDS，改为实际连接串：
# postgresql://user:password@your-rds-endpoint.rds.aliyuncs.com:5432/dorm_management?schema=public
DATABASE_URL="postgresql://postgres:postgres@db:5432/dorm_management?schema=public"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=dorm_management

# JWT 密钥（生产环境必须更换，至少 32 位随机字符串）
JWT_SECRET=your-production-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-production-refresh-secret-min-32-chars

# 服务器配置
PORT=3000
NODE_ENV=production

# 前端地址（改为实际域名或IP）
FRONTEND_URL=http://localhost

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# 阿里云 OSS（可选，如不使用则保持为空）
OSS_REGION=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=
